{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/logos/*", "/data/*"]
  },
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff"
  }
}
