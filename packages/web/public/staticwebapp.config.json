{
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Cache-Control": "no-cache"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/logos/*",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/logos/*", "/data/*", "*.ico", "*.png", "*.gif", "*.svg"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
